NODE_ENV=development
PORT=3000
HOST=0.0.0.0

MONGO_URI=mongodb://127.0.0.1:27017/policyguard
JWT_SECRET=replace-with-a-strong-secret
JWT_EXPIRY=7d

FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=
EXTENSION_ALLOWED_IDS=

MAX_REQUEST_SIZE=5mb
REQUEST_TIMEOUT_MS=30000
ANALYSIS_REQUEST_TIMEOUT_MS=120000

LOG_LEVEL=info

REDIS_ENABLED=false
REDIS_URL=redis://127.0.0.1:6379
REDIS_CACHE_PREFIX=policyguard

CACHE_DASHBOARD_TTL_SEC=180
CACHE_HISTORY_TTL_SEC=120
CACHE_ANALYSIS_TTL_SEC=300
CACHE_CHAT_SESSION_TTL_SEC=3600
CACHE_EXTENSION_QUICK_TTL_SEC=120

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_ANALYSIS_MAX=30
RATE_LIMIT_CHATBOT_MAX=60
RATE_LIMIT_GENERAL_MAX=180

QUEUE_ENABLED=false
QUEUE_PREFIX=policyguard-jobs
ANALYSIS_JOB_ATTEMPTS=2
ANALYSIS_JOB_BACKOFF_MS=2000

EXTENSION_TOKEN_MAX_AGE_SEC=604800
